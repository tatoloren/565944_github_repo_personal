      "[1, 1, 1, 1]\n"
     ]
    }
   ],
   "source": [
    "# Crear una matriz de unos de 3 x 4\n",
    "matriz2 = matriz_unos(3, 4)\n",
    "mostrar_matriz(matriz2)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d8c6665c",
   "metadata": {},
   "source": [
    "## Matriz identidad"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8c7ebee5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def matriz_identidad(n_filas, n_columnas):\n",
    "    matriz = []\n",
    "    for i in range(n_filas):\n",
    "        fila = []\n",
    "        for j in range(n_columnas):\n",
    "            fila.append(1 if i == j else 0)\n",
    "        matriz.append(fila)\n",
    "    return matriz"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ea138de3",
   "metadata": {},
   "outputs": [
